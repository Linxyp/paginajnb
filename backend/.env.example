# Puerto donde corre la API backend
PORT=4000

# URL exacta del frontend permitida por CORS (sin barra final)
FRONTEND_URL=http://localhost:3000

# Secreto de integridad de Wompi (Panel Wompi > Desarrolladores > Llaves).
# Opcional por ahora: mientras no exista, el endpoint /api/payments/wompi-signature
# responde 503 y el checkout usa "pago contra entrega" / WhatsApp.
WOMPI_INTEGRITY_SECRET=
